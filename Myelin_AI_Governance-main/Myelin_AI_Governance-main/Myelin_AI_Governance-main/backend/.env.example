# Backend environment template
# Copy to .env and fill values

APP_NAME=Myelin AI Governance API
APP_VERSION=2.0.0
DEBUG=True
ENABLE_DOCS=True
API_V1_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Security
SECRET_KEY=replace-with-random-secret
API_KEY_PREFIX=myelin_sk_
API_KEY_LENGTH=32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Firebase
FIREBASE_CREDENTIALS_JSON=C:/path/to/your/firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_ID=(default)
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4173,http://127.0.0.1:4173,http://localhost:5500,http://127.0.0.1:5500,http://localhost:5501,http://127.0.0.1:5501
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-API-Key,X-Request-ID,Accept

# Network hardening
TRUSTED_HOSTS=localhost,127.0.0.1,0.0.0.0
CLOUDFLARE_ENABLED=False
MAX_REQUEST_BODY_BYTES=2097152

# Rate limiting
RATE_LIMIT_AUDIT=10/minute
RATE_LIMIT_AUTH=20/minute
RATE_LIMIT_BATCH=5/minute
RATE_LIMIT_DEFAULT=60/minute

# JWT
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_MINUTES=10080
JWT_ALGORITHM=HS256

# Bot/anomaly controls
BOT_BLOCK_THRESHOLD=50
BOT_DRY_RUN=True
ANOMALY_MONITOR_ENABLED=True
INPUT_SANITIZER_ENABLED=True

# Rule engine
DEFAULT_RATE_LIMIT_PER_MINUTE=60
RULE_CACHE_TTL_SECONDS=300
MAX_CUSTOM_RULES_PER_ORG=100
PUBLIC_DEMO_KEY_ENABLED=False

# Email system
EMAIL_ENABLED=False
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your-email@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_USE_TLS=True
EMAIL_VERIFICATION_BASE_URL=http://localhost:8000/api/v1/auth/verify-email
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
