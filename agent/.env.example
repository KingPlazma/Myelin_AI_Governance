# Myelin Sentinel Agent environment template

# Downstream LLM endpoint
TARGET_LLM_URL=http://localhost:11434/v1/chat/completions

# Agent mode
MYELIN_STRICT_MODE=true

# Agent alert delivery
# Recommended: keep fallback disabled and pass backend API key in X-API-Key or Authorization Bearer header.
# This ensures recipient email is resolved from verified user account.
AGENT_ALLOW_FALLBACK_EMAIL=false
AGENT_ALERT_EMAIL_HEADER=X-User-Email
AGENT_ALERT_EMAIL=
