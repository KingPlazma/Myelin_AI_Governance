# Myelin Sentinel Agent environment template

# Service identity and runtime
MYELIN_SERVICE_NAME=Myelin Sentinel Agent Proxy
MYELIN_SERVICE_VERSION=1.1.0
MYELIN_HOST=0.0.0.0
MYELIN_PORT=9000
MYELIN_LOG_LEVEL=INFO
MYELIN_OPERATIONAL_TOKEN=change-me-for-ops

# Downstream LLM provider
MYELIN_PROVIDER_TYPE=openai_compatible
MYELIN_PROVIDER_API_KEY=
TARGET_LLM_URL=http://localhost:11434/v1/chat/completions
TARGET_LLM_HEALTH_URL=http://localhost:11434/v1/models
MYELIN_REQUEST_TIMEOUT_SECONDS=120

# Governance behavior
MYELIN_STRICT_MODE=true
MYELIN_REDACT_REQUEST_BODIES_IN_LOGS=false
MYELIN_INCIDENT_DB_PATH=./data/incidents.sqlite3

# Agent alert delivery
# Recommended: keep fallback disabled and pass backend API key in X-API-Key or Authorization Bearer header.
# This ensures recipient email is resolved from verified user account.
AGENT_ALLOW_FALLBACK_EMAIL=false
AGENT_ALERT_EMAIL_HEADER=X-User-Email
AGENT_ALERT_EMAIL=
