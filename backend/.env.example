# Backend environment template
# Copy to .env and fill values

APP_NAME=Myelin AI Governance API
APP_VERSION=2.0.0
DEBUG=True
API_V1_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Security
SECRET_KEY=replace-with-random-secret
API_KEY_PREFIX=myelin_sk_
API_KEY_LENGTH=32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Firebase
FIREBASE_CREDENTIALS_JSON=../serviceAccountKey.json
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# CORS — list ONLY your real frontend domains. NEVER use "*" in production.
# Cloudflare passes the browser's Origin header through unchanged, so exact
# domain matching works correctly when behind Cloudflare.
# Production example:
# CORS_ORIGINS=https://app.myelin.com,https://dashboard.myelin.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-API-Key,X-Request-ID,Accept

# Trusted Hosts — rejects requests with invalid/spoofed Host headers.
# Production example: TRUSTED_HOSTS=api.myelin.com,myelin.com
TRUSTED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Cloudflare — set True when traffic comes through Cloudflare.
# Enables CF-Connecting-IP header trust for real IP extraction.
CLOUDFLARE_ENABLED=True

# Payload size limit — max request body in bytes (default 2 MB)
MAX_REQUEST_BODY_BYTES=2097152

# Rate Limits (slowapi format: "N/period")
RATE_LIMIT_AUDIT=10/minute
RATE_LIMIT_AUTH=20/minute
RATE_LIMIT_BATCH=5/minute
RATE_LIMIT_DEFAULT=60/minute

# Rule engine
DEFAULT_RATE_LIMIT_PER_MINUTE=60
RULE_CACHE_TTL_SECONDS=300
MAX_CUSTOM_RULES_PER_ORG=100
PUBLIC_DEMO_KEY_ENABLED=False

# Email system
EMAIL_ENABLED=False
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your-email@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_USE_TLS=True
EMAIL_VERIFICATION_BASE_URL=http://localhost:8000/api/v1/auth/verify-email
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
