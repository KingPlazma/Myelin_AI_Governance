{
  "manifest_version": 3,
  "name": "Myelin Sentinel Extension",
  "version": "0.2.0",
  "description": "Browser-side controls for the Myelin Sentinel agent and audit APIs.",

  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; object-src 'none'; base-uri 'none'"
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Myelin Sentinel",
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "chrome://*/*",
        "chrome-extension://*/*",
        "about:*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}

