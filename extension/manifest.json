{
  "manifest_version": 3,
  "name": "Myelin Sentinel Extension",
  "version": "0.1.0",
  "description": "Browser-side controls for the Myelin Sentinel agent and audit APIs.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:9000/*",
    "http://127.0.0.1:8000/*",
    "http://127.0.0.1:9000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Myelin Sentinel",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
